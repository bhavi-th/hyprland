{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "center",
  "positionY": "bottom",
  "cssPriority": "user",
  "layer": "overlay",
  "layer-shell": true,

  "control-center-layer": "top",
  "control-center-width": 400,
  "control-center-height": 600,
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 16,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,

  "notification-window-width": 400,
  "notification-window-height": 800,
  "notification-icon-size": 70,
  "notification-body-image-height": 50,
  "notification-body-image-width": 50,
  "notification-2fa-action": true,
  "notifications-inline-replies": true,

  "timeout": 4,
  "timeout-low": 4,
  "timeout-critical": 4,

  "fit-to-screen": false,
  "relative-timestamps": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": ["mpris", "title", "notifications"],

  "widget-config": {
    "title": {
      "text": "",
      "clear-all-button": true,
      "button-text": "󰩺  Clear"
    },

    "dnd": {
      "text": "DND"
    },

    "mpris": {
      "image-size": 76,
      "image-radius": 10
    }
  }
}
